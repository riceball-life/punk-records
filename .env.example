# Copy to `.env` and fill in from your Supabase project:
#   Dashboard → Project Settings → API
#
# The anon key is a PUBLIC key and is meant to ship in the client bundle;
# Row-Level Security (see supabase/schema.sql) is what keeps data private.
#
# Leaving these unset is fine — the app runs in local-only mode (no sync).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
